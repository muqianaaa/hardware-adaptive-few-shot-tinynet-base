LR_IROM1 0x08000000 0x00100000  {    ; load region size_region
  ER_IROM1 0x08000000 0x00100000  {  ; load address = execution address
   *.o (RESET, +First)
   *(InRoot$$Sections)
   .ANY (+RO)
   .ANY (+XO)
  }
  RW_IRAM2 0x10000000 0x00010000  {  ; CCM SRAM (64 KB)
   main.o (ccmram, +ZI)
  }
  RW_IRAM1 0x20000000 0x00020000  {  ; Main SRAM (128 KB)
   .ANY (+RW +ZI)
  }
}

